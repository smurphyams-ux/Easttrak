{
  "name": "easytrak-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "frontend": "cd web && vite --port 3001 --host --strictPort",
    "backend": "PORT=3002 node server/server.js",
    "dev": "npm run backend & npm run frontend",
    "build": "npm install --prefix web && npm install --prefix server && npm --prefix web run build",
    "preview": "vite preview",
    "start": "npm --prefix server start"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/jspdf": "^1.3.3",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-plaid-link": "^4.1.1",
    "react-router-dom": "^6.21.0",
    "stripe": "^20.4.1",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^8.0.2"
  },
  "private": true
}
